{
    "manifest_version": 3,
    "name": "Linkarooie",
    "version": "1.0",
    "description": "Hop Your Way Through the Web.",
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
      }
    },
    "permissions": ["activeTab", "storage"],
    "background": {
      "service_worker": "background.js"
    },
    "chrome_url_overrides": {
      "newtab": "popup.html"
    }
  }
  